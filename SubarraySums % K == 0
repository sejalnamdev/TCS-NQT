class Solution:
    def subarraysDivByK(self, nums: List[int], k: int) -> int:
        res = 0
        f = {}
        sum = 0
        f[0] = 1
        
        for i in range(len(nums)):
            sum += nums[i]

            rem = sum % k
            if rem < 0:
                rem = rem + k

            res = f.get(rem, 0) + res

            f[rem] = f.get(rem, 0) + 1

        return res
        